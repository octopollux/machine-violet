{
  "name": "machine-violet",
  "version": "1.0.1",
  "description": "Machine Violet — an agentic AI Dungeon Master that runs any tabletop RPG in a terminal",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node --max-semi-space-size=16 dist/index.js",
    "dev": "cross-env DEV_MODE=true node --max-semi-space-size=16 --import tsx/esm src/index.tsx",
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs'),p=require('path');[['src/prompts','dist/prompts','.md'],['src/tui/themes/assets','dist/tui/themes/assets','.theme'],['src/tui/themes/assets','dist/tui/themes/assets','.player-frame']].forEach(([s,d,ext])=>{fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).filter(f=>f.endsWith(ext)).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))})\"",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "check": "eslint src/ && vitest run --coverage",
    "dist": "node scripts/build-dist.js"
  },
  "keywords": [
    "rpg",
    "tui",
    "cli",
    "game",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "clipboardy": "^5.3.1",
    "dotenv": "^16.4.5",
    "fflate": "^0.8.2",
    "ink": "^6.8.0",
    "ink-scroll-view": "^0.3.6",
    "isomorphic-git": "^1.37.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "postject": "^1.0.0-alpha.6",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.0",
    "ink-testing-library": "^4.0.0",
    "rcedit": "^5.0.2",
    "react-devtools-core": "^7.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "tools/campaign-explorer"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
