{
  "name": "machine-violet",
  "version": "1.0.1",
  "description": "Machine Violet — an agentic AI Dungeon Master that runs any tabletop RPG in a terminal",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node --max-semi-space-size=16 dist/index.js",
    "dev": "node --import tsx/esm scripts/dev-two-tier.js",
    "dev:launcher": "node --max-semi-space-size=16 --import tsx/esm scripts/launcher.ts",
    "build": "tsc",
    "build:all": "npm run build -w packages/shared && npm run build -w packages/engine && npm run build -w packages/client-ink",
    "test": "npm test -w packages/engine && npm test -w packages/client-ink",
    "test:watch": "vitest",
    "test:coverage": "npm test -w packages/engine -- --coverage && npm test -w packages/client-ink -- --coverage",
    "lint": "eslint packages/shared/src/ packages/engine/src/ packages/client-ink/src/",
    "typecheck": "npm run -w packages/shared build && npm run -w packages/engine typecheck && npm run -w packages/client-ink typecheck",
    "check": "npm run lint && npm run test",
    "dist": "node scripts/build-dist.js"
  },
  "keywords": [
    "rpg",
    "tui",
    "cli",
    "game",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "clipboardy": "^5.3.1",
    "dotenv": "^16.4.5",
    "fflate": "^0.8.2",
    "ink": "^6.8.0",
    "ink-scroll-view": "^0.3.6",
    "isomorphic-git": "^1.37.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "postject": "^1.0.0-alpha.6",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.0",
    "ink-testing-library": "^4.0.0",
    "rcedit": "^5.0.2",
    "react-devtools-core": "^7.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "packages/*",
    "tools/campaign-explorer"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
