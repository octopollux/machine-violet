{
  "name": "tui-rpg-engine",
  "version": "1.0.0",
  "description": "A console TUI RPG engine powered by Claude AI and Ink",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "keywords": [
    "rpg",
    "tui",
    "cli",
    "game",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5",
    "ink": "^5.0.1",
    "ink-scroll-view": "^0.3.6",
    "isomorphic-git": "^1.37.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
