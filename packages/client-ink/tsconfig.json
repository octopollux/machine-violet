{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", "dist",
    "src/**/*.test.ts", "src/**/*.test.tsx",
    "src/phases/**/*",
    "src/commands/**/*",
    "src/tui/hooks/useGameCallbacks.ts"
  ],
  "references": [
    { "path": "../shared" }
  ]
}
